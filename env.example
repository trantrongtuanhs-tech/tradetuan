# ─── REQUIRED ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── OPTIONAL ─────────────────────────────────────────────────────────────────
# Binance API key (optional — public data doesn't require auth)
BINANCE_API_KEY=
BINANCE_SECRET=

# spot | future  (use "future" for USDT-M perpetuals on Binance Futures)
MARKET_TYPE=spot

# How often to scan (minutes)
SCAN_INTERVAL_MINUTES=60

# Also send WEAK signals (not just CONFIRMED)?  true | false
SEND_WEAK_SIGNALS=true

# Comma-separated list of symbols to scan
TOP_COINS=BTC/USDT,ETH/USDT,BNB/USDT,SOL/USDT,XRP/USDT,ADA/USDT,AVAX/USDT,DOT/USDT,MATIC/USDT,LINK/USDT,UNI/USDT,ATOM/USDT,LTC/USDT,BCH/USDT,FIL/USDT,APT/USDT,ARB/USDT,OP/USDT,SUI/USDT,INJ/USDT,NEAR/USDT,FTM/USDT,SAND/USDT,MANA/USDT,AXS/USDT
